<!-- Custom Wazuh rule: SSH Brute Force Detection -->
<!-- Author: Frank Ewasy Odoom Jnr (Pixelz) -->

<group name="custom,ssh,bruteforce">

  <rule id="100001" level="10" frequency="5" timeframe="60">
    <if_matched_sid>5716</if_matched_sid>
    <same_source_ip/>
    <description>SSH brute force attack detected: 5 failed attempts in 60 seconds from same IP</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failures,pci_dss_10.2.4,pci_dss_10.2.5</group>
  </rule>

  <rule id="100002" level="14" frequency="20" timeframe="120">
    <if_matched_sid>5716</if_matched_sid>
    <same_source_ip/>
    <description>SSH brute force attack escalated: 20 failed attempts in 120 seconds — possible automated attack</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failures,pci_dss_10.2.4,pci_dss_10.2.5</group>
  </rule>

  <rule id="100003" level="15">
    <if_matched_sid>100001</if_matched_sid>
    <if_sid>5715</if_sid>
    <same_source_ip/>
    <description>Successful SSH login after brute force attempt — possible account compromise</description>
    <mitre>
      <id>T1110.001</id>
      <id>T1078</id>
    </mitre>
    <group>authentication_success,pci_dss_10.2.4,pci_dss_10.2.5</group>
  </rule>

</group>